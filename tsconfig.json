{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node18",
    "lib": ["ES2022"],
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "isolatedModules": true,
    "noImplicitAny": false,
    "types": ["node", "jest"]
  },
  "include": ["src", "prisma/generated"],
  "exclude": ["node_modules", "dist"]
}
